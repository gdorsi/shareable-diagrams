{
  "name": "shareable-diagrams",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:skill": "esbuild skills/share-diagram/scripts/encode.src.mjs --bundle --platform=node --format=esm --target=node22 --outfile=skills/share-diagram/scripts/encode.mjs --loader:.wasm=binary --banner:js='const require=(await import(\"node:module\")).createRequire(import.meta.url);'",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@comark/react": "^0.2.1",
    "@shikijs/themes": "^4.0.2",
    "beautiful-mermaid": "^1.1.3",
    "jazz-tools": "^2.0.0-alpha.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
